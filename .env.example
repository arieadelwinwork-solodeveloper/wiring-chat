# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth — set false untuk production / live
DEV_BYPASS_AUTH=false
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_USER_ROLE=owner

# Supabase (isi saat connect ke project Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# DeepSeek — model AI yang aktif saat ini
# Dapatkan key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Provider lain (belum tersedia di UI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Frontend (Vite) — WAJIB di Netlify (bukan Render). Prefix VITE_ wajib.
# Nilai ini di-embed saat `npm run build`, jadi set di Netlify lalu trigger redeploy.
VITE_USE_API=true
VITE_API_URL=https://YOUR-RENDER-APP.onrender.com/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Provider OAuth untuk tombol O'Apps (google, github, dll.)
VITE_OAPPS_OAUTH_PROVIDER=google
